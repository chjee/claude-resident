#!/bin/bash
# =====================================================
# claude-resident — Claude Code + Telegram 에이전트 관리
# =====================================================
# 사용법:
#   claude-resident <name> [start|stop|restart|status|check|health|shutdown|cleanup-memory|logs|attach]
#
# 예:
#   claude-resident andy start
#   claude-resident andy stop
#   claude-resident andy restart
#   claude-resident andy status
#   claude-resident andy check
#   claude-resident andy health
#   claude-resident andy cleanup-memory
#   claude-resident andy logs
#   claude-resident andy attach
#
# 별칭: cr
# =====================================================

INSTANCE="${1:?사용법: claude-resident <name> [start|stop|restart|status|check|health|shutdown|cleanup-memory|logs|attach]}"
CMD="${2:-start}"

# 인스턴스 설정/상태 디렉토리
INSTANCE_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/claude-resident/$INSTANCE"
INSTANCE_STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/claude-resident/$INSTANCE"
LOG_FILE="$INSTANCE_STATE_DIR/agent.log"
# Used by sourced modules under lib/claude-resident.
# shellcheck disable=SC2034
HEALTH_STATE_FILE="$INSTANCE_STATE_DIR/health-state.json"
MEMORY_DIR="$INSTANCE_CONFIG_DIR/memory"
# shellcheck disable=SC2034
DAILY_DIR="$MEMORY_DIR/daily"
# shellcheck disable=SC2034
DAILY_LOCK_DIR="$MEMORY_DIR/.daily.lock"
DEFAULT_TELEGRAM_STATE_DIR="$INSTANCE_CONFIG_DIR/telegram"

# tmux 세션 이름
# shellcheck disable=SC2034
SESSION="claude-resident-$INSTANCE"

# Claude Code 바이너리와 작업 디렉토리
CLAUDE_BIN="${CLAUDE_BIN:-$(command -v claude 2>/dev/null || true)}"
[ -n "$CLAUDE_BIN" ] || CLAUDE_BIN="$HOME/.local/bin/claude"
WORKSPACE_DIR="${CLAUDE_RESIDENT_WORKSPACE_DIR:-$HOME/workspace}"
# shellcheck disable=SC2034
BUN_BIN_DIR="${BUN_INSTALL:-$HOME/.bun}/bin"

# 디렉토리 초기화
mkdir -p "$INSTANCE_CONFIG_DIR" "$INSTANCE_STATE_DIR" "$MEMORY_DIR"

# .env에서 텔레그램 설정 로드 (인스턴스별 .env 우선, 없으면 omx-bridge .env fallback)
INSTANCE_ENV_FILE="$INSTANCE_CONFIG_DIR/.env"
ENV_FILE="${CLAUDE_RESIDENT_OMX_BRIDGE_ENV_FILE:-$WORKSPACE_DIR/omx-bridge/.env}"
for _env in "$INSTANCE_ENV_FILE" "$ENV_FILE"; do
  if [ -f "$_env" ]; then
    while IFS='=' read -r key val || [ -n "$key" ]; do
      key="${key#"${key%%[![:space:]]*}"}"
      key="${key%"${key##*[![:space:]]}"}"
      case "$key" in
        ""|\#*) continue ;;
      esac
      key="${key#export }"
      key="${key#"${key%%[![:space:]]*}"}"
      key="${key%"${key##*[![:space:]]}"}"

      val="${val%$'\r'}"
      val="${val#"${val%%[![:space:]]*}"}"
      val="${val%"${val##*[![:space:]]}"}"
      val="${val#\"}"
      val="${val%\"}"
      val="${val#\'}"
      val="${val%\'}"

      case "$key" in
        TELEGRAM_BOT_TOKEN|TELEGRAM_NOTIFY_CHAT_ID|WEBHOOK_PORT|TELEGRAM_STATE_DIR|\
        CLAUDE_RESIDENT_PERMISSION_MODE|CLAUDE_RESIDENT_STARTUP_DELAY_SEC|\
        CLAUDE_RESIDENT_TRIGGER_RETRY_DELAY_SEC|CLAUDE_RESIDENT_RESTART_DELAY_SEC|\
        CLAUDE_RESIDENT_STARTUP_RETRIES|CLAUDE_RESIDENT_SHUTDOWN_RETRIES|\
        CLAUDE_RESIDENT_SHUTDOWN_WAIT_SEC|CLAUDE_RESIDENT_DAILY_RETENTION_DAYS|\
        CLAUDE_RESIDENT_LOG_ROTATE_BYTES)
          # 인스턴스 .env가 우선 — 이미 설정된 값은 덮어쓰지 않음
          [ -z "${!key}" ] && export "$key=$val"
          ;;
      esac
    done < "$_env"
  fi
done
TELEGRAM_STATE_DIR="${TELEGRAM_STATE_DIR:-$DEFAULT_TELEGRAM_STATE_DIR}"
# Used by sourced modules under lib/claude-resident.
# shellcheck disable=SC2034
PERMISSION_MODE="${CLAUDE_RESIDENT_PERMISSION_MODE:-bypassPermissions}"
# shellcheck disable=SC2034
STARTUP_TRIGGER_DELAY_SEC="${CLAUDE_RESIDENT_STARTUP_DELAY_SEC:-5}"
# shellcheck disable=SC2034
TRIGGER_RETRY_DELAY_SEC="${CLAUDE_RESIDENT_TRIGGER_RETRY_DELAY_SEC:-2}"
RESTART_DELAY_SEC="${CLAUDE_RESIDENT_RESTART_DELAY_SEC:-2}"
# shellcheck disable=SC2034
STARTUP_TRIGGER_RETRIES="${CLAUDE_RESIDENT_STARTUP_RETRIES:-3}"
# shellcheck disable=SC2034
SHUTDOWN_TRIGGER_RETRIES="${CLAUDE_RESIDENT_SHUTDOWN_RETRIES:-2}"
# shellcheck disable=SC2034
SHUTDOWN_WAIT_SEC="${CLAUDE_RESIDENT_SHUTDOWN_WAIT_SEC:-20}"
# shellcheck disable=SC2034
DAILY_RETENTION_DAYS="${CLAUDE_RESIDENT_DAILY_RETENTION_DAYS:-60}"
# shellcheck disable=SC2034
LOG_ROTATE_BYTES="${CLAUDE_RESIDENT_LOG_ROTATE_BYTES:-10485760}"

log() {
  local line
  line=$(printf '[%s] %s' "$(date '+%Y-%m-%d %H:%M:%S')" "$*")
  printf '%s\n' "$line"
  if ! printf '%s\n' "$line" >> "$LOG_FILE"; then
    printf 'WARN: failed to write log file: %s\n' "$LOG_FILE" >&2
  fi
}

timestamp_now() {
  date '+%Y-%m-%dT%H:%M:%S%z'
}

json_escape() {
  local value="${1:-}"
  value=${value//\\/\\\\}
  value=${value//\"/\\\"}
  value=${value//$'\n'/\\n}
  value=${value//$'\r'/\\r}
  value=${value//$'\t'/\\t}
  printf '%s' "$value"
}

json_string_or_null() {
  local value="${1:-}"
  if [ -n "$value" ]; then
    printf '"%s"' "$(json_escape "$value")"
  else
    printf 'null'
  fi
}

json_bool_or_null() {
  case "${1:-}" in
    true|false) printf '%s' "$1" ;;
    *) printf 'null' ;;
  esac
}

json_encoder_available() {
  command -v jq >/dev/null 2>&1 || command -v python3 >/dev/null 2>&1
}

load_resident_libs() {
  local script_dir
  local lib_dir=""
  local lib_file

  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  if [ -n "${CLAUDE_RESIDENT_LIB_DIR:-}" ]; then
    lib_dir="$CLAUDE_RESIDENT_LIB_DIR"
  elif [ -d "$script_dir/lib/claude-resident" ]; then
    lib_dir="$script_dir/lib/claude-resident"
  elif [ -d "$script_dir/../lib/claude-resident" ]; then
    lib_dir="$(cd "$script_dir/../lib/claude-resident" && pwd)"
  fi

  if [ -z "$lib_dir" ]; then
    printf 'ERROR: claude-resident lib directory not found\n' >&2
    return 1
  fi

  for lib_file in telegram.sh health.sh memory.sh lifecycle.sh check.sh; do
    if [ ! -f "$lib_dir/$lib_file" ]; then
      printf 'ERROR: missing claude-resident lib file: %s\n' "$lib_dir/$lib_file" >&2
      return 1
    fi
    # shellcheck source=/dev/null
    . "$lib_dir/$lib_file"
  done
}

load_resident_libs || exit 1

case "$CMD" in
  start)    start ;;
  stop)     stop ;;
  restart)  stop; sleep "$RESTART_DELAY_SEC"; start ;;
  status)   status ;;
  check)    check ;;
  health)   health ;;
  shutdown) shutdown ;;  # systemd ExecStop 전용
  cleanup-memory) cleanup_memory ;;
  logs)     logs ;;
  attach)   attach_session ;;
  *)        echo "사용법: claude-resident <name> [start|stop|restart|status|check|health|shutdown|cleanup-memory|logs|attach]" ;;
esac
