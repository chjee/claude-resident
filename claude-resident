#!/bin/bash
# =====================================================
# claude-resident — Claude Code + Telegram 에이전트 관리
# =====================================================
# 사용법:
#   claude-resident <name> [start|stop|restart|status|shutdown]
#
# 예:
#   claude-resident andy start
#   claude-resident andy stop
#   claude-resident andy restart
#   claude-resident andy status
#
# 별칭: cr
# =====================================================

INSTANCE="${1:?사용법: claude-resident <name> [start|stop|restart|status|shutdown]}"
CMD="${2:-start}"

# 인스턴스 설정/상태 디렉토리
INSTANCE_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/claude-resident/$INSTANCE"
INSTANCE_STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/claude-resident/$INSTANCE"
LOG_FILE="$INSTANCE_STATE_DIR/agent.log"
MEMORY_DIR="$INSTANCE_CONFIG_DIR/memory"

# tmux 세션 이름
SESSION="claude-resident-$INSTANCE"

# Claude Code 바이너리와 작업 디렉토리
CLAUDE_BIN="${CLAUDE_BIN:-$(command -v claude 2>/dev/null || true)}"
[ -n "$CLAUDE_BIN" ] || CLAUDE_BIN="$HOME/.local/bin/claude"
WORKSPACE_DIR="${CLAUDE_RESIDENT_WORKSPACE_DIR:-$HOME/workspace}"

# 디렉토리 초기화
mkdir -p "$INSTANCE_CONFIG_DIR" "$INSTANCE_STATE_DIR" "$MEMORY_DIR"

# .env에서 텔레그램 설정 로드 (인스턴스별 .env 우선, 없으면 omx-bridge .env fallback)
INSTANCE_ENV_FILE="$INSTANCE_CONFIG_DIR/.env"
ENV_FILE="${CLAUDE_RESIDENT_OMX_BRIDGE_ENV_FILE:-$WORKSPACE_DIR/omx-bridge/.env}"
for _env in "$INSTANCE_ENV_FILE" "$ENV_FILE"; do
  if [ -f "$_env" ]; then
    while IFS='=' read -r key val; do
      case "$key" in
        TELEGRAM_BOT_TOKEN|TELEGRAM_NOTIFY_CHAT_ID)
          # 인스턴스 .env가 우선 — 이미 설정된 값은 덮어쓰지 않음
          [ -z "${!key}" ] && export "$key=$val"
          ;;
      esac
    done < "$_env"
  fi
done

send_startup_trigger() {
  # Claude 세션이 안정화되길 기다린 후 __STARTUP__ 트리거 전송
  sleep 5
  if [ -z "$TELEGRAM_BOT_TOKEN" ] || [ -z "$TELEGRAM_NOTIFY_CHAT_ID" ]; then
    echo "[$INSTANCE] WARN: TELEGRAM_BOT_TOKEN 또는 TELEGRAM_NOTIFY_CHAT_ID 없음 — startup 트리거 생략" | tee -a "$LOG_FILE"
    return
  fi

  HTTP_STATUS=$(curl -s -o /dev/null -w "%{http_code}" -X POST \
    "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage" \
    -H "Content-Type: application/json" \
    -d "{\"chat_id\": \"${TELEGRAM_NOTIFY_CHAT_ID}\", \"text\": \"__STARTUP__\"}")

  if [ "$HTTP_STATUS" = "200" ]; then
    echo "[$INSTANCE] startup 트리거 전송 성공 (HTTP $HTTP_STATUS)" | tee -a "$LOG_FILE"
  else
    echo "[$INSTANCE] ERROR: startup 트리거 전송 실패 (HTTP $HTTP_STATUS) — 수동으로 __STARTUP__ 전송 필요" | tee -a "$LOG_FILE"
  fi
}

start() {
  if tmux has-session -t "$SESSION" 2>/dev/null; then
    echo "$INSTANCE 이미 실행 중."
    echo "접속: tmux attach -t $SESSION"
    return
  fi

  if [ ! -x "$CLAUDE_BIN" ]; then
    echo "ERROR: Claude Code 바이너리를 찾지 못함: $CLAUDE_BIN"
    return 1
  fi

  if [ ! -f "$INSTANCE_CONFIG_DIR/CLAUDE.md" ]; then
    echo "WARN: $INSTANCE_CONFIG_DIR/CLAUDE.md 없음 — resident startup 규칙이 로드되지 않을 수 있음"
  fi

  echo "$INSTANCE 시작 중..."
  # bun이 PATH에 없어도 플러그인이 동작하도록 보장
  BUN_BIN_DIR="${BUN_INSTALL:-$HOME/.bun}/bin"
  case ":$PATH:" in *":$BUN_BIN_DIR:"*) ;; *) PATH="$BUN_BIN_DIR:$PATH" ;; esac

  claude_cmd=(env "CLAUDE_CODE_ADDITIONAL_DIRECTORIES_CLAUDE_MD=1" "PATH=$PATH" "$CLAUDE_BIN")
  if [ -d "$WORKSPACE_DIR" ]; then
    claude_cmd+=(--add-dir "$WORKSPACE_DIR")
  else
    echo "WARN: workspace 디렉토리 없음 — --add-dir 생략: $WORKSPACE_DIR"
  fi
  claude_cmd+=(--channels "plugin:telegram@claude-plugins-official")
  claude_cmd+=(--permission-mode bypassPermissions)

  printf -v claude_cmd_string '%q ' "${claude_cmd[@]}"

  tmux new-session -d -s "$SESSION" \
    -c "$INSTANCE_CONFIG_DIR" \
    -e "CLAUDE_RESIDENT_INSTANCE=$INSTANCE" \
    -e "CLAUDE_RESIDENT_CONFIG_DIR=$INSTANCE_CONFIG_DIR" \
    -e "CLAUDE_RESIDENT_STATE_DIR=$INSTANCE_STATE_DIR" \
    "${claude_cmd_string}"

  # pipe-pane으로 로깅 (PTY를 유지한 채 출력 캡처)
  tmux pipe-pane -t "$SESSION" "cat >> '$LOG_FILE'"

  # 백그라운드에서 startup 트리거 전송
  send_startup_trigger &

  echo "$INSTANCE 시작됨."
  echo "접속: tmux attach -t $SESSION"
  echo "로그: tail -f $LOG_FILE"
}

stop() {
  if tmux has-session -t "$SESSION" 2>/dev/null; then
    tmux kill-session -t "$SESSION"
    echo "$INSTANCE 종료됨."
  else
    echo "$INSTANCE 실행 중 아님."
  fi
}

shutdown() {
  # systemd ExecStop 전용 — recent.md 저장 후 종료
  echo "[$INSTANCE] 종료 신호 수신 — recent.md 저장 요청 중..." | tee -a "$LOG_FILE"

  if [ -n "$TELEGRAM_BOT_TOKEN" ] && [ -n "$TELEGRAM_NOTIFY_CHAT_ID" ]; then
    curl -s -o /dev/null -X POST \
      "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage" \
      -H "Content-Type: application/json" \
      -d "{\"chat_id\": \"${TELEGRAM_NOTIFY_CHAT_ID}\", \"text\": \"__SHUTDOWN__\"}"
    echo "[$INSTANCE] __SHUTDOWN__ 전송 완료 — 20초 대기 (recent.md 저장 시간)" | tee -a "$LOG_FILE"
    sleep 20
  else
    echo "[$INSTANCE] WARN: 텔레그램 설정 없음 — 즉시 종료" | tee -a "$LOG_FILE"
  fi

  stop
}

status() {
  if tmux has-session -t "$SESSION" 2>/dev/null; then
    echo "✅ $INSTANCE 실행 중 (tmux session: $SESSION)"
    tmux list-sessions -F "  세션: #{session_name} | 생성: #{session_created_string}" \
      -f "#{==:#{session_name},$SESSION}"
    echo "  설정: $INSTANCE_CONFIG_DIR"
    echo "  상태: $INSTANCE_STATE_DIR"
    echo "  로그: $LOG_FILE"
  else
    echo "❌ $INSTANCE 실행 중 아님"
  fi
}

case "$CMD" in
  start)    start ;;
  stop)     stop ;;
  restart)  stop; sleep 2; start ;;
  status)   status ;;
  shutdown) shutdown ;;  # systemd ExecStop 전용
  *)        echo "사용법: claude-resident <name> [start|stop|restart|status|shutdown]" ;;
esac
